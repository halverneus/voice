import { ComboBox, VerticalBox, HorizontalBox } from "std-widgets.slint";

// ─── Color palette – Catppuccin Mocha ─────────────────────────────────────────
global Theme {
    out property <color> bg:       #1e1e2e;
    out property <color> mantle:   #181825;
    out property <color> crust:    #11111b;
    out property <color> surface0: #313244;
    out property <color> surface1: #45475a;
    out property <color> surface2: #585b70;
    out property <color> overlay0: #6c7086;
    out property <color> subtext:  #a6adc8;
    out property <color> text:     #cdd6f4;
    out property <color> mauve:    #cba6f7;
    out property <color> blue:     #89b4fa;
    out property <color> green:    #a6e3a1;
    out property <color> red:      #f38ba8;
    out property <color> yellow:   #f9e2af;
    out property <color> peach:    #fab387;
}

// ─── Main window ──────────────────────────────────────────────────────────────
export component MainWindow inherits Window {
    title: "Voice Dictation";
    preferred-width: 440px;
    min-width: 360px;
    background: Theme.bg;

    // ── State ─────────────────────────────────────────────────────────────────
    in-out property <bool>   is-listening:  false;
    in-out property <bool>   is-processing: false;
    in-out property <bool>   is-loading:    false;
    in-out property <string> status-text:   "Ready";
    in-out property <string> transcript:    "";

    // Model selection
    in-out property <[string]> model-names:      [];
    in-out property <int>      model-index:       0;
    in-out property <bool>     model-missing:     false;
    in-out property <bool>     downloading:       false;
    in-out property <string>   download-status:   "";
    in-out property <float>    download-progress: 0;

    // Device
    in-out property <[string]> device-names: [];
    in-out property <int>      device-index: 0;

    // Inject method: 0 = wtype, 1 = ydotool
    in-out property <int> inject-method-index: 0;

    // Output mode: 0 = inject into window, 1 = append to file
    in-out property <int>    output-mode-index: 0;
    in-out property <string> output-file-path:  "";

    // Panel visibility
    in-out property <bool> show-settings: false;

    // ── Callbacks ─────────────────────────────────────────────────────────────
    callback toggle-dictation();
    callback model-changed(int);
    callback device-changed(int);
    callback inject-method-changed(int);
    callback download-model();
    callback output-mode-changed(int);
    callback choose-output-file();

    // ── Root layout ───────────────────────────────────────────────────────────
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // ══════ Header bar ════════════════════════════════════════════════════
        Rectangle {
            height: 48px;
            background: Theme.mantle;

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.surface0;
            }

            // Status dot (absolute position, vertically centred)
            Rectangle {
                x: 16px;
                y: (parent.height - 8px) / 2;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: (root.is-loading || root.is-processing) ? Theme.yellow :
                             root.is-listening                       ? Theme.green  :
                                                                       Theme.surface1;
                animate background { duration: 300ms; }
            }

            // App title
            Text {
                x: 32px;
                y: 0px;
                width: parent.width - 76px;
                height: parent.height;
                text: "Voice Dictation";
                color: Theme.text;
                font-size: 14px;
                font-weight: 600;
                vertical-alignment: center;
            }

            // Settings gear button
            Rectangle {
                x: parent.width - 44px;
                y: (parent.height - 32px) / 2;
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: root.show-settings ? Theme.surface0 : transparent;
                animate background { duration: 150ms; }

                Text {
                    x: 0px; y: 0px;
                    width: parent.width;
                    height: parent.height;
                    text: "⚙";
                    color: root.show-settings ? Theme.mauve : Theme.subtext;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    animate color { duration: 150ms; }
                }
                TouchArea {
                    x: 0px; y: 0px;
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => { root.show-settings = !root.show-settings; }
                }
            }
        }

        // ══════ Main content ══════════════════════════════════════════════════
        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 12px;

            // ── Transcript area ───────────────────────────────────────────────
            Rectangle {
                height: 82px;
                border-radius: 8px;
                background: Theme.mantle;
                border-width: 1px;
                border-color: root.is-listening ? Theme.surface1 : Theme.surface0;
                clip: true;
                animate border-color { duration: 300ms; }

                // Left accent bar
                Rectangle {
                    x: 0px; y: 0px;
                    width: 3px;
                    height: parent.height;
                    background: (root.is-loading || root.is-processing) ? Theme.yellow :
                                 root.is-listening                       ? Theme.green  :
                                                                           Theme.surface0;
                    animate background { duration: 300ms; }
                }

                Text {
                    x: 14px;
                    y: 10px;
                    width: parent.width - 22px;
                    height: parent.height - 20px;
                    text: root.transcript == "" ? "Transcript will appear here…" : root.transcript;
                    color: root.transcript == "" ? Theme.overlay0 : Theme.subtext;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-alignment: top;
                    overflow: elide;
                }
            }

            // ── Output mode toggle ────────────────────────────────────────────
            HorizontalLayout {
                spacing: 4px;

                // Inject tab
                Rectangle {
                    height: 32px;
                    horizontal-stretch: 1;
                    border-radius: 6px;
                    background: root.output-mode-index == 0 ? Theme.mauve : Theme.surface0;
                    border-width: 1px;
                    border-color: root.output-mode-index == 0 ? Theme.mauve : Theme.surface1;
                    animate background  { duration: 180ms; }
                    animate border-color { duration: 180ms; }

                    Text {
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        text: "⌨  Inject";
                        color: root.output-mode-index == 0 ? Theme.crust : Theme.subtext;
                        font-size: 12px;
                        font-weight: root.output-mode-index == 0 ? 700 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 180ms; }
                    }
                    TouchArea {
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => {
                            root.output-mode-index = 0;
                            root.output-mode-changed(0);
                        }
                    }
                }

                // File Append tab
                Rectangle {
                    height: 32px;
                    horizontal-stretch: 1;
                    border-radius: 6px;
                    background: root.output-mode-index == 1 ? Theme.blue : Theme.surface0;
                    border-width: 1px;
                    border-color: root.output-mode-index == 1 ? Theme.blue : Theme.surface1;
                    animate background  { duration: 180ms; }
                    animate border-color { duration: 180ms; }

                    Text {
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        text: "↗  File Append";
                        color: root.output-mode-index == 1 ? Theme.crust : Theme.subtext;
                        font-size: 12px;
                        font-weight: root.output-mode-index == 1 ? 700 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 180ms; }
                    }
                    TouchArea {
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => {
                            root.output-mode-index = 1;
                            root.output-mode-changed(1);
                            // Auto-open settings to pick a file if none chosen yet
                            if root.output-file-path == "" {
                                root.show-settings = true;
                            }
                        }
                    }
                }
            }

            // ── File path indicator (shown when file mode + file chosen) ──────
            if root.output-mode-index == 1 && root.output-file-path != "" : Rectangle {
                height: 28px;
                border-radius: 6px;
                background: Theme.mantle;
                border-width: 1px;
                border-color: Theme.blue;

                Text {
                    x: 10px; y: 0px;
                    width: parent.width - 20px;
                    height: parent.height;
                    text: "↗  " + root.output-file-path;
                    color: Theme.blue;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            // ── Control row ───────────────────────────────────────────────────
            HorizontalLayout {
                spacing: 14px;
                alignment: start;

                // Start / Stop button
                Rectangle {
                    width: 106px;
                    height: 40px;
                    border-radius: 20px;
                    background: root.is-listening  ? Theme.red   :
                                root.is-loading    ? Theme.yellow :
                                                     Theme.mauve;
                    opacity: (!root.is-loading && !root.downloading) ? 1.0 : 0.5;
                    animate background { duration: 250ms; }
                    animate opacity    { duration: 150ms; }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 7px;
                        padding: 0px;

                        // Circle → Square morphs when recording
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: root.is-listening ? 1px : 4px;
                            background: Theme.crust;
                            animate border-radius { duration: 200ms; }
                        }

                        Text {
                            text: root.is-loading   ? "Loading…" :
                                  root.is-listening ? "Stop"     :
                                                      "Start";
                            color: Theme.crust;
                            font-size: 13px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }

                    TouchArea {
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        enabled: !root.is-loading && !root.downloading;
                        mouse-cursor: pointer;
                        clicked => { root.toggle-dictation(); }
                    }
                }

                // Status dot + text
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    horizontal-stretch: 1;

                    Rectangle {
                        width: 6px;
                        height: 6px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 3px;
                        background: (root.is-loading || root.is-processing) ? Theme.yellow :
                                     root.is-listening                       ? Theme.green  :
                                                                               Theme.surface2;
                        animate background { duration: 200ms; }
                    }

                    Text {
                        text: root.status-text;
                        color: Theme.subtext;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                }
            }
        }

        // ══════ Settings panel ════════════════════════════════════════════════
        if root.show-settings : Rectangle {
            background: Theme.mantle;

            // Top border
            Rectangle {
                y: 0px;
                height: 1px;
                background: Theme.surface0;
            }

            VerticalLayout {
                padding-left: 16px;
                padding-right: 16px;
                padding-top: 14px;
                padding-bottom: 14px;
                spacing: 10px;

                // Section label
                Text {
                    text: "SETTINGS";
                    color: Theme.overlay0;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 1.5px;
                }

                // Model row
                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Text {
                        text: "Model";
                        color: Theme.subtext;
                        font-size: 12px;
                        vertical-alignment: center;
                        min-width: 56px;
                    }
                    ComboBox {
                        model: root.model-names;
                        current-index <=> root.model-index;
                        horizontal-stretch: 1;
                        selected => { root.model-changed(self.current-index); }
                    }
                }

                // Mic row
                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Text {
                        text: "Mic";
                        color: Theme.subtext;
                        font-size: 12px;
                        vertical-alignment: center;
                        min-width: 56px;
                    }
                    ComboBox {
                        model: root.device-names;
                        current-index <=> root.device-index;
                        horizontal-stretch: 1;
                        selected => { root.device-changed(self.current-index); }
                    }
                }

                // Inject method (only relevant in inject mode)
                if root.output-mode-index == 0 : HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Text {
                        text: "Method";
                        color: Theme.subtext;
                        font-size: 12px;
                        vertical-alignment: center;
                        min-width: 56px;
                    }
                    ComboBox {
                        model: ["wtype (Wayland)", "ydotool (uinput)"];
                        current-index <=> root.inject-method-index;
                        horizontal-stretch: 1;
                        selected => { root.inject-method-changed(self.current-index); }
                    }
                }

                // Output file picker (only in file append mode)
                if root.output-mode-index == 1 : HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Text {
                        text: "File";
                        color: Theme.subtext;
                        font-size: 12px;
                        vertical-alignment: center;
                        min-width: 56px;
                    }

                    // Path display (truncated)
                    Rectangle {
                        height: 32px;
                        border-radius: 6px;
                        background: Theme.surface0;
                        border-width: 1px;
                        border-color: Theme.surface1;
                        horizontal-stretch: 1;
                        clip: true;

                        Text {
                            x: 8px; y: 0px;
                            width: parent.width - 16px;
                            height: parent.height;
                            text: root.output-file-path == "" ?
                                  "No file selected…" : root.output-file-path;
                            color: root.output-file-path == "" ? Theme.overlay0 : Theme.text;
                            font-size: 11px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    // Browse button
                    Rectangle {
                        width: 68px;
                        height: 32px;
                        border-radius: 6px;
                        background: Theme.surface0;
                        border-width: 1px;
                        border-color: Theme.surface1;

                        Text {
                            x: 0px; y: 0px;
                            width: parent.width;
                            height: parent.height;
                            text: "Browse";
                            color: Theme.text;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            x: 0px; y: 0px;
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => { root.choose-output-file(); }
                        }
                    }
                }

                // Download section (only when model file is missing)
                if root.model-missing : VerticalLayout {
                    spacing: 8px;

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: start;

                        Rectangle {
                            width: 134px;
                            height: 32px;
                            border-radius: 8px;
                            background: root.downloading ? Theme.surface0 : Theme.mauve;
                            opacity: root.downloading ? 0.6 : 1.0;
                            animate background { duration: 150ms; }
                            animate opacity    { duration: 150ms; }

                            Text {
                                x: 0px; y: 0px;
                                width: parent.width;
                                height: parent.height;
                                text: root.downloading ? "Downloading…" : "Download Model";
                                color: root.downloading ? Theme.subtext : Theme.crust;
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                x: 0px; y: 0px;
                                width: parent.width;
                                height: parent.height;
                                enabled: !root.downloading;
                                mouse-cursor: pointer;
                                clicked => { root.download-model(); }
                            }
                        }

                        Text {
                            text: root.download-status;
                            color: Theme.subtext;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }

                    // Progress bar
                    if root.downloading : Rectangle {
                        height: 4px;
                        border-radius: 2px;
                        background: Theme.surface1;

                        Rectangle {
                            x: 0px; y: 0px;
                            width: root.download-progress * parent.width;
                            height: parent.height;
                            border-radius: 2px;
                            background: Theme.mauve;
                            animate width { duration: 200ms; }
                        }
                    }
                }
            }
        }
    }
}
